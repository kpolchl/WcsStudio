<!DOCTYPE html>
<html lang={@locale} class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix="">
      <%= assigns[:page_title] || "WcsStudio" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}> </script>
  </head>
  <style>
      body {
          overscroll-behavior: auto;
      }
      html {
          background: #f0f0f0; /* the color shown in the overscroll area */
      }

  </style>
  <body class="bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 min-h-screen font-sans text-slate-200 flex flex-col">

    <%= @inner_content %>

  <footer class="bg-slate-900/80 border-t border-slate-700/50 mt-auto">
      <div class="px-4 py-4">
          <div class="flex flex-col md:flex-row justify-between items-start">
              <div class="md:mb-0">
                  <a href="/" class="text-xl font-bold bg-gradient-to-r from-pink-500 to-purple-500 bg-clip-text text-transparent">
                      WcsStudio
                  </a>
                  <p class="text-slate-400 text-sm mt-2"> <%= gettext("Master the art of partner dancing") %></p>
              </div>
          </div>
          <div class="text-center mt-4 pt-2 border-t border-slate-700/30">
              <p class="text-slate-500 text-sm">&copy; <%= DateTime.utc_now().year %> WcsStudio. All rights reserved.</p>
          </div>
      </div>
  </footer>
  </body>
</html>
