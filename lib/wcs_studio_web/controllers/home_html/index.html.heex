<!-- Stats Section -->
<section class="py-20 bg-slate-800/50 backdrop-blur-sm border-y border-slate-700/50">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
