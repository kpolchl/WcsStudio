<section class="relative w-full overflow-hidden h-screen mt-[-128px] ">
    <div id="carousel" class="flex transition-transform duration-700 ease-in-out h-full">
        <!-- Slide 1 -->
        <div class="w-full flex-shrink-0 relative h-full">
            <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900"></div>
            <div class="absolute inset-0 bg-black opacity-40"></div>
                <div class="absolute inset-0 bg-gradient-to-r from-pink-500/10 to-purple-500/10"></div>
            <div class="absolute inset-0 flex flex-col justify-center items-start text-left px-8 md:px-16 lg:px-24">
                <h2 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 opacity-0 animate-[slideUp_0.8s_ease-out_0.2s_forwards]">
                    <%= gettext("Dance") %><span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-purple-400"> <%= gettext("Elevated") %></span>
                </h2>
                <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-2xl opacity-0 animate-[slideUp_0.8s_ease-out_0.4s_forwards]">
                    <%= gettext("Master the art of movement comprehensive resources") %>
                </p>
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="w-full flex-shrink-0 relative h-full">
            <div class="absolute inset-0 bg-gradient-to-br from-purple-900 via-pink-900 to-slate-900"></div>
            <div class="absolute inset-0 bg-black opacity-30"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-pink-500/10 to-purple-500/10"></div>
            <div class="absolute inset-0 flex flex-col justify-center items-start text-left px-8 md:px-16 lg:px-24">
                <h2 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 opacity-0 animate-[slideUp_0.8s_ease-out_0.2s_forwards]">
                     <%= gettext("Perfect Your") %> <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-purple-400"> <%= gettext("Technique") %></span>
                </h2>
                <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-2xl opacity-0 animate-[slideUp_0.8s_ease-out_0.4s_forwards]">
                     <%= gettext("Step-by-step patterns and some instruction for dancers at admin level") %>
                </p>
            </div>
        </div>

        <!-- Slide 3 -->
        <div class="w-full flex-shrink-0 relative h-full">
            <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-purple-900 to-pink-900"></div>
            <div class="absolute inset-0 bg-black opacity-25"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-pink-500/10 to-purple-500/10"></div>
            <div class="absolute inset-0 flex flex-col justify-center items-start text-left px-8 md:px-16 lg:px-24">
                <h2 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 opacity-0 animate-[slideUp_0.8s_ease-out_0.2s_forwards]">
                      <%= gettext("Join Our") %><span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-purple-400"> <%= gettext("Community") %></span>
                </h2>
                <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-2xl opacity-0 animate-[slideUp_0.8s_ease-out_0.4s_forwards]">
                     <%= gettext("Connect with passionate dancers") %>
                </p>
            </div>
        </div>
    </div>

    <!-- Navigation Arrows -->
    <button id="prev"
            class="absolute top-1/2 left-2 sm:left-4 p-3 sm:p-4 transform -translate-y-1/2 bg-slate-800/50 backdrop-blur-sm rounded-xl hover:bg-slate-700/50 border border-slate-700/50 transition-all duration-300 group z-10">
        <i class="fas fa-chevron-left text-white text-lg group-hover:scale-110 transition-transform"></i>
    </button>
    <button id="next"
            class="absolute top-1/2 right-2 sm:right-4 p-3 sm:p-4 transform -translate-y-1/2 bg-slate-800/50 backdrop-blur-sm rounded-xl  hover:bg-slate-700/50 border border-slate-700/50 transition-all duration-300 group z-10">
        <i class="fas fa-chevron-right text-white text-lg group-hover:scale-110 transition-transform"></i>
    </button>

    <!-- Indicators -->
    <div class="absolute bottom-4 sm:bottom-8 left-1/2 transform -translate-x-1/2 flex space-x-3 z-10">
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white bg-opacity-50 hover:bg-opacity-100 transition-all duration-300"></button>
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white bg-opacity-50 hover:bg-opacity-100 transition-all duration-300"></button>
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white bg-opacity-50 hover:bg-opacity-100 transition-all duration-300"></button>
    </div>
</section>

